# Copia este archivo a backend/.env y completa los valores reales.
# .env nunca se commitea (ver .gitignore).

# Clave de la API de MiniMax — sin esto, el bot usa una plantilla determinística
# (funciona igual, pero sin redacción por IA).
MINIMAX_API_KEY=

# Endpoint de MiniMax. api.minimaxi.chat es el usado en producción;
# api.minimax.io es la alternativa según la región de tu cuenta.
MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
MINIMAX_MODEL=MiniMax-M3

# Ruta de los navegadores de Playwright dentro del contenedor (ya fijada
# por el Dockerfile — normalmente no hace falta tocarla).
PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
PLAYWRIGHT_HEADFUL=0
